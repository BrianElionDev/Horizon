{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "JWT_SECRET",
        "JWT_ACCESS_EXPIRY",
        "FRONTEND_URL",
        "PORT",
        "NODE_ENV"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },

    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}
