{
  "name": "horizon",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @horizon/web dev",
    "dev:api": "pnpm --filter @horizon/api dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:seed": "pnpm --filter @horizon/api db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "turbo": "^2.9.6",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
